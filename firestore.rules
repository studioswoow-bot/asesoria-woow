rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNCIONES DE SEGURIDAD
    // ==========================================
    
    // Verifica si el usuario está autenticado y tiene rol de staff en el proyecto 7288e
    function isStaff() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'monitor');
    }

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 🛡️ BLOQUEO DE ESCRITURA EN CORE (AISLAMIENTO TOTAL)
    // Estas colecciones NO deben ser modificadas por esta App.
    // ==========================================
    
    match /models/{modelId} {
      allow read: if isStaff(); 
      allow write: if false; // ⛔ PROHIBIDO: Solo lectura desde esta app
    }

    match /daily_metrics/{metricId} {
      allow read: if isStaff();
      allow write: if false; // ⛔ PROHIBIDO: Protege el historial financiero
    }

    match /work_hours/{hourId} {
      allow read: if isStaff();
      allow write: if false; // ⛔ PROHIBIDO
    }
    
    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow write: if false; // ⛔ PROHIBIDO
    }

    match /financial_transactions/{id} {
      allow read: if isStaff();
      allow write: if false; // ⛔ PROHIBIDO
    }

    // Preservar acceso al estudio y habitaciones como staff pero sin escritura desde aquí
    match /studio/{documentId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /users/{userId} {
      // Necesario filtro por query en algunos casos
      allow list: if request.auth != null
                  && request.query.limit <= 1 
                  && request.query.filters.size() == 1
                  && request.query.filters[0].op == '==' 
                  && request.query.filters[0].field == 'username';
      allow read: if isStaff();
      allow write: if isAdmin(); // Solo Admins reales pueden tocar la tabla de usuarios
    }

    // ==========================================
    // ✅ COLECCIONES DE ASESORÍA (ESCRITURA PERMITIDA)
    // Aquí es donde esta aplicación guarda su información.
    // ==========================================
    
    // Planes de Acción y Seguimiento Quincenal
    match /modelos_action_plans_v2/{planId} {
      allow read, write: if isStaff();
    }
    
    // Perfiles extendidos de optimización
    match /modelos_profile_v2/{profileId} {
      allow read, write: if isStaff();
    }

    // Integraciones de API y Nicknames
    match /modelos_api_integrations/{apiId} {
      allow read, write: if isStaff();
    }

    // Caché de Analítica para el Dashboard
    match /modelos_analytics_cache_v2/{cacheId} {
      allow read, write: if isStaff();
    }

    // Logs de sincronización de plataformas
    match /chaturbate_logs/{logId} {
      allow read, write: if isStaff();
    }

    // ==========================================
    // BLOQUEO POR DEFECTO
    // ==========================================
    match /{document=**} {
      allow read: if isStaff();
      allow write: if false;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNCIONES DE SEGURIDAD
    // ==========================================
    
    // Obtiene los datos del usuario actual una sola vez para eficiencia
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si el usuario es Staff (Admin o Monitor)
    function isStaff() {
      let role = getUserData().role;
      return request.auth != null && (role == 'admin' || role == 'monitor');
    }

    // Verifica si el usuario es una Modelo
    function isModel() {
      return request.auth != null && getUserData().role == 'model';
    }

    // Obtiene el ID de modelo asociado al usuario actual
    function currentUserModelId() {
      return getUserData().modelId;
    }

    // Verifica si el usuario es dueño de los datos de una modelo específica
    function isOwner(modelId) {
      return isModel() && currentUserModelId() == modelId;
    }

    // ==========================================
    // 🛡️ REGLAS DE ACCESO PARA MODELOS
    // Permite que las modelos vean SOLO su propia información.
    // ==========================================

    // Colección principal de Modelos (V1)
    match /models/{modelId} {
      allow read: if isStaff() || isOwner(modelId);
      allow write: if isStaff(); // Solo Staff puede modificar la ficha técnica base
    }

    // Colecciones de la App de Asesoría (V2)
    match /modelos_profile_v2/{modelId} {
      allow read: if isStaff() || isOwner(modelId);
      allow write: if isStaff();
    }
    
    match /modelos_profile_history_v2/{historyId} {
      // Nota: El ID aquí suele ser timestamp#modelId o similar, verificamos el campo de datos
      allow read: if isStaff() || (isModel() && resource.data.modelId == currentUserModelId());
    }

    match /modelos_analytics_cache_v2/{cacheId} {
      allow read: if isStaff() || (isModel() && resource.data.model_id == currentUserModelId());
    }

    // Métricas y Horas de Trabajo
    match /daily_metrics/{metricId} {
      allow read: if isStaff() || (isModel() && resource.data.model_id == currentUserModelId());
      allow write: if isStaff();
    }

    match /work_hours/{workId} {
      allow read: if isStaff() || (isModel() && resource.data.model_id == currentUserModelId());
      allow write: if isStaff();
    }

    match /modelos_action_plans_v2/{planId} {
      allow read: if isStaff() || (isModel() && resource.data.modelId == currentUserModelId());
      allow write: if isStaff();
    }

    // ==========================================
    // 🛡️ REGLAS GENERALES Y STAFF
    // ==========================================

    // Los usuarios pueden leer su propio documento en 'users' para que la app cargue
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isStaff();
    }

    // Permitir acceso total al Staff para el resto de la base de datos (Operatividad)
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
